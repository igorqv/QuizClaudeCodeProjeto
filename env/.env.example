# Supabase: Settings > Database > Connection string > Transaction mode (pooled - porta 6543)
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true&connection_limit=1"

# Supabase: Settings > Database > Connection string > Session mode (direto - porta 5432)
# Usado pelo Prisma Migrate (não pelo runtime)
DIRECT_URL="postgresql://user:password@host:5432/postgres"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"

# Development
NEXTAUTH_URL="http://localhost:3000"
# Production (Vercel): set to your deployed URL, e.g. https://quizbrasil.vercel.app
