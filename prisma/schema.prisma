generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model GuestPlayer {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  bestScore   Int           @default(0)
  gamesPlayed Int           @default(0)
  createdAt   DateTime      @default(now())

  sessions GameSession[]

  @@index([email])
}

model Question {
  id            String @id @default(cuid())
  number        Int    @unique
  theme         String
  difficulty    String
  basePoints    Int
  questionText  String
  correctAnswer String
  wrongAnswer1  String
  wrongAnswer2  String
  wrongAnswer3  String
  explanation   String

  sessionAnswers SessionAnswer[]

  @@index([theme, difficulty])
}

model GameSession {
  id           String        @id @default(cuid())
  guestId      String
  guest        GuestPlayer   @relation(fields: [guestId], references: [id])
  score        Int           @default(0)
  correctCount Int           @default(0)
  status       SessionStatus @default(in_progress)
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?

  answers SessionAnswer[]

  @@index([guestId])
}

model SessionAnswer {
  id           String      @id @default(cuid())
  sessionId    String
  session      GameSession @relation(fields: [sessionId], references: [id])
  questionId   String
  question     Question    @relation(fields: [questionId], references: [id])
  chosenAnswer String
  isCorrect    Boolean
  timeSpentMs  Int
  pointsEarned Int
  answeredAt   DateTime    @default(now())
}

enum SessionStatus {
  in_progress
  completed
  abandoned
}
